# ============================================================
# FullStackAutoQuant - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Tushare API (https://tushare.pro) ---
# Required for market data and real-time quotes
TUSHARE=your_tushare_token_here

# --- JoinQuant / GM Trade API (gmtrade SDK) ---
# Required only for live/simulation trading execution
# Endpoint: api.myquant.cn:9000 for cloud simulation (also set in configs/trading.yaml)
GM_ENDPOINT=api.myquant.cn:9000
GM_TOKEN=
GM_ACCOUNT_ID=

# --- Multi-Account Trading (run_trading.sh / run_full_pipeline.sh) ---
# Comma-separated GM account IDs for multi-account simultaneous trading.
# Each account executes identical orders from the same signal source.
# Example: TRADE_ACCOUNTS=aaaa-bbbb-...,cccc-dddd-...
TRADE_ACCOUNTS=

# --- Pipeline Control ---
# Set to "1" for dry-run (no orders placed). Remove or "0" for live trading.
TRADE_DRY_RUN=1

# --- Qlib Data Directory (optional, default: ~/.qlib/qlib_data/cn_data) ---
# QLIB_DATA_DIR=~/.qlib/qlib_data/cn_data

{
  "project": {
    "name": "FullStackAutoQuant",
    "description": "End-to-End Deep Learning Quantitative Trading System",
    "author": "Zizhao Huang",
    "license": "CC-BY-NC-SA-4.0",
    "repository": "https://github.com/Zizhao-HUANG/FullStackAutoQuant"
  },
  "model": {
    "name": "TCN_LocalAttn_GRU_L72_RankMSE_Balanced_v2",
    "type": "TimeSeries",
    "total_parameters": 246209,
    "trainable_parameters": 246209,
    "input_features": 22,
    "input_timesteps": 72,
    "d_model": 96,
    "gru_hidden_size": 48,
    "attention_heads": 6,
    "attention_head_dim": 16,
    "dropout": 0.1,
    "window_size": 16,
    "window_stride": 8,
    "architecture_components": [
      "Linear Embedding (22→96)",
      "3× Residual TCN Blocks (causal convolution, GELU, dilation)",
      "Post-TCN Projection (64→96)",
      "Overlapping Local Self-Attention (causal mask, window=16, stride=8)",
      "GRU Head (96→48, unidirectional)",
      "Output MLP (48→32→1, GELU + Dropout)"
    ]
  },
  "training": {
    "n_epochs": 95,
    "learning_rate": 0.0002,
    "batch_size": 256,
    "weight_decay": 0.0001,
    "precision": "bf16",
    "loss_function": "0.7*PairwiseHinge(m=0.015)+0.3*MSE + TVR(4e-4)",
    "optimizer": "AdamW",
    "lr_scheduler": "CosineAnnealingLRWithWarmup",
    "gradient_clip_norm": 0.8,
    "seed": 42,
    "step_len": 72,
    "rank_loss_margin": 0.015,
    "rank_mse_blend_alpha": 0.7,
    "turnover_regularization": 0.0004
  },
  "data_pipeline": {
    "universe": "csi300",
    "start_time": "2005-01-04",
    "end_time": "2025-07-30",
    "alpha_features": [
      "RESI5",
      "WVMA5",
      "RSQR5",
      "KLEN",
      "RSQR10",
      "CORR5",
      "CORD5",
      "CORR10",
      "ROC60",
      "RESI10",
      "VSTD5",
      "RSQR60",
      "CORR60",
      "WVMA60",
      "STD5",
      "RSQR20",
      "CORD60",
      "CORD10",
      "CORR20",
      "KLOW"
    ],
    "num_alpha_features": 20,
    "custom_factors": 2,
    "total_features": 22,
    "normalization": "RobustZScoreNorm (fit: 2005-01-04 to 2021-12-31, clip_outlier=True)",
    "label": "5-day asymmetric return × volume ratio",
    "segments": {
      "train": [
        "2005-01-04",
        "2021-12-31"
      ],
      "valid": [
        "2022-01-04",
        "2023-12-29"
      ],
      "test": [
        "2024-01-02",
        "2025-07-30"
      ]
    },
    "step_len": 72
  },
  "backtest_config": {
    "benchmark": "SH000300",
    "initial_capital": 100000000,
    "start_time": "2024-01-02",
    "end_time": "2025-07-30",
    "transaction_costs": {
      "open_cost": 0.0005,
      "close_cost": 0.0015,
      "min_cost": 5
    },
    "strategy": {
      "class": "TopkDropoutStrategy",
      "topk": 50,
      "n_drop": 5
    }
  },
  "inference": {
    "mc_dropout_samples": 16,
    "confidence_metric": "1 / (1 + std(MC predictions))",
    "normalization": "Cached RobustZScoreNorm (norm_params.pkl)",
    "device": "CPU"
  }
}